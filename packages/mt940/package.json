{
  "name": "@finparse/mt940",
  "version": "0.1.0",
  "description": "SWIFT MT940/MT942 bank statement parser — coming in v0.2",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist"],
  "scripts": { "build": "tsup", "dev": "tsup --watch" },
  "dependencies": { "@finparse/core": "workspace:*" },
  "keywords": ["fintech", "banking", "mt940", "swift", "finance", "parser"],
  "license": "MIT"
}
