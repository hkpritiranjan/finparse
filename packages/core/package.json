{
  "name": "@finparse/core",
  "version": "0.1.0",
  "description": "Core types, schema, and interfaces for finparse",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "keywords": [
    "fintech",
    "banking",
    "ofx",
    "mt940",
    "camt",
    "bai2",
    "finance"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
